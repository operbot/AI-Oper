{
  "manifest_version": 3,
  "name": "AI Operator Assistant",
  "version": "0.1.0",
  "description": "AI assistant for webcam platform operators",
  "icons": {
    "16": "public/icons/icon16.png",
    "48": "public/icons/icon48.png",
    "128": "public/icons/icon128.png"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "public/icons/icon16.png",
      "48": "public/icons/icon48.png",
      "128": "public/icons/icon128.png"
    },
    "default_title": "AI Operator"
  },
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/index.ts-loader-DEqUB8eB.js"
      ],
      "matches": [
        "*://*.chaturbate.com/*",
        "*://*.stripchat.com/*",
        "*://*.bongacams.com/*"
      ],
      "run_at": "document_idle"
    },
    {
      "js": [
        "assets/sidebar-entry.tsx-loader-DKIvXjzy.js"
      ],
      "matches": [
        "*://*.chaturbate.com/*"
      ],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "*://*.chaturbate.com/*",
    "*://*.stripchat.com/*",
    "*://*.bongacams.com/*",
    "https://*.supabase.co/*",
    "wss://*.supabase.co/*",
    "https://api.anthropic.com/*",
    "https://api.openai.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://openrouter.ai/*"
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "*://*.bongacams.com/*",
        "*://*.chaturbate.com/*",
        "*://*.stripchat.com/*"
      ],
      "resources": [
        "assets/BZg2qN70.js",
        "assets/TQB5KC7h.js",
        "assets/DoTST0Rt.js"
      ],
      "use_dynamic_url": false
    },
    {
      "matches": [
        "*://*.chaturbate.com/*"
      ],
      "resources": [
        "assets/wMFxaBOg.js",
        "assets/TQB5KC7h.js",
        "assets/BZg2qN70.js",
        "assets/DvV4QBec.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
